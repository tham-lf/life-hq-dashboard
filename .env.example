# Copy this file to ".env" and paste your Notion internal integration token.
# Use the SAME integration the gym-session-prep routine uses (it already has
# access to the Gym hub + its databases). Get/copy it from:
#   https://www.notion.so/my-integrations  ->  your integration  ->  Internal Integration Secret
# The token starts with "ntn_".  Never commit the real .env.
NOTION_TOKEN=ntn_paste_your_token_here
